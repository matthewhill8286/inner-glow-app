EXPO_PUBLIC_OPENAI_API_KEY="your-openai-api-key-here"

# Stripe (publishable key only — secret key goes in Supabase Edge Function secrets)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key"

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-supabase-anon-key

# Supabase Edge Function Secrets (set via CLI, NOT in .env):
# supabase secrets set STRIPE_SECRET_KEY="sk_test_..."
# supabase secrets set STRIPE_WEBHOOK_SECRET="whsec_..."
# supabase secrets set OPENAI_API_KEY="sk-proj-..."
